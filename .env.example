# Example environment for مزارع أبو صبح — copy to `.env` and adjust.
# (.env is gitignored; this example IS committed.)

# Database — MySQL (provider is "mysql" in prisma/schema.prisma).
#   mysql://USER:PASSWORD@HOST:3306/DBNAME
# On Hostinger the app and DB share a host, so production uses HOST=localhost.
# To run `prisma db push` / `db seed` from your own machine, use the Remote MySQL
# host from hPanel (and whitelist your IP under Databases → Remote MySQL).
DATABASE_URL="mysql://user:password@localhost:3306/abusubh"

# Demo owner password — hashed by prisma/seed.ts into the seeded User row.
SEED_OWNER_PASSWORD="abusubh2026"

# Session signing secret — HMAC key for the auth cookie. MUST be changed in production.
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
